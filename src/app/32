"use client";

import { useState } from "react";
import { createEvent } from "../features/event/event.service";
import { parseEventText } from "../features/parser/parser";
import type { Event, Role } from "../features/event/event.types";

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${d.getFullYear()}/${d.getMonth() + 1}/${d.getDate()} ${d.getHours()}:${String(d.getMinutes()).padStart(2, "0")}`;
}

export default function Page() {
  const [events, setEvents] = useState<Event[]>([]);
  const [inputText, setInputText] = useState("");
  const [currentWorkspaceType, setCurrentWorkspaceType] =
    useState<"private" | "business">("private");

  const currentRole: Role = "admin";

  const deleteMode = {
    private: "direct",
    business: "approval",
  } as const;

  const handleRegister = (e?: React.FormEvent<HTMLFormElement>) => {
    if (e) e.preventDefault();

    const trimmed = inputText.trim();

    if (!trimmed) {
      alert("入力して");
      return;
    }

    const parsed = parseEventText(trimmed);
    const dt = parsed.parsedDateTime;

    if (!dt) {
      alert("解析できない");
      return;
    }

    const date = new Date(
      dt.year,
      dt.month - 1,
      dt.day,
      dt.hour,
      dt.minute
    );

    if (isNaN(date.getTime())) {
      alert("日付おかしい");
      return;
    }

    if (typeof document !== "undefined") {
      const active = document.activeElement as HTMLElement | null;
      active?.blur();
    }

    const confirmText = [
      "この内容で登録する？",
      "",
      `タイトル: ${parsed.title}`,
      `開始: ${formatDate(date.toISOString())}`,
      `workspace: ${currentWorkspaceType}`,
      `タグ: ${parsed.tags.length > 0 ? parsed.tags.join(" / ") : "なし"}`,
    ].join("\n");

    const ok = window.confirm(confirmText);

    if (!ok) {
      return;
    }

    const event = createEvent({
      title: parsed.title,
      tags: parsed.tags,
      start_at: date.toISOString(),
      end_at: null,
      all_day: false,
      workspace_type: currentWorkspaceType,
      workspace_id:
        currentWorkspaceType === "private"
          ? "private-main"
          : "business-main",
      created_by: "me",
    });

    setEvents((prev) => [...prev, event]);
    setInputText("");
  };

  const handleDelete = (id: string, workspaceType: "private" | "business") => {
    if (deleteMode[workspaceType] === "direct") {
      setEvents((prev) =>
        prev.map((e) =>
          e.id === id
            ? {
                ...e,
                delete_status: "deleted",
                updated_at: new Date().toISOString(),
              }
            : e
        )
      );
      return;
    }

    setEvents((prev) =>
      prev.map((e) =>
        e.id === id
          ? {
              ...e,
              delete_status: "requested",
              delete_requested_by: "me",
              delete_requested_at: new Date().toISOString(),
              delete_review_result: "pending",
              updated_at: new Date().toISOString(),
            }
          : e
      )
    );
  };

  const handleApprove = (id: string) => {
    if (
      currentRole !== "admin" &&
      currentRole !== "owner" &&
      currentRole !== "owner_ceo"
    ) {
      return;
    }

    setEvents((prev) =>
      prev.map((e) =>
        e.id === id
          ? {
              ...e,
              delete_status: "deleted",
              delete_reviewed_by: "me",
              delete_reviewed_at: new Date().toISOString(),
              delete_review_result: "approved",
              updated_at: new Date().toISOString(),
            }
          : e
      )
    );
  };

  const filteredEvents = events.filter(
    (e) =>
      e.workspace_type === currentWorkspaceType &&
      e.delete_status !== "deleted"
  );

  return (
    <div
      style={{
        padding: 20,
        color: "white",
        background: "#111",
        minHeight: "100vh",
      }}
    >
      <h1>チャベス</h1>

      <div
        style={{
          display: "flex",
          gap: 8,
          marginBottom: 16,
          flexWrap: "wrap",
        }}
      >
        <button
          type="button"
          onClick={() => setCurrentWorkspaceType("private")}
          style={{
            padding: "10px 14px",
            border: "1px solid white",
            background: currentWorkspaceType === "private" ? "white" : "#222",
            color: currentWorkspaceType === "private" ? "black" : "white",
            cursor: "pointer",
            minHeight: 44,
          }}
        >
          private
        </button>

        <button
          type="button"
          onClick={() => setCurrentWorkspaceType("business")}
          style={{
            padding: "10px 14px",
            border: "1px solid white",
            background: currentWorkspaceType === "business" ? "white" : "#222",
            color: currentWorkspaceType === "business" ? "black" : "white",
            cursor: "pointer",
            minHeight: 44,
          }}
        >
          business
        </button>
      </div>

      <div style={{ marginBottom: 16 }}>
        <div>workspace: {currentWorkspaceType}</div>
        <div>role: {currentRole}</div>
      </div>

      <form
        onSubmit={handleRegister}
        style={{
          display: "flex",
          gap: 8,
          marginBottom: 16,
          flexWrap: "wrap",
          alignItems: "center",
        }}
      >
        <input
          type="text"
          value={inputText}
          onChange={(e) => setInputText(e.target.value)}
          placeholder="例: 来週金曜重要会議"
          style={{
            padding: "10px 12px",
            border: "1px solid white",
            background: "#222",
            color: "white",
            width: 320,
            maxWidth: "100%",
            minHeight: 44,
            fontSize: 16,
          }}
        />

        <button
          type="submit"
          style={{
            padding: "10px 14px",
            border: "1px solid white",
            background: "#222",
            color: "white",
            cursor: "pointer",
            minHeight: 44,
          }}
        >
          登録
        </button>
      </form>

      <h2>予定一覧</h2>

      {filteredEvents.length === 0 && <p>このworkspaceの予定はまだなし</p>}

      {filteredEvents.map((e) => (
        <div
          key={e.id}
          style={{
            marginBottom: 14,
            padding: 12,
            border: "1px solid #444",
          }}
        >
          <div>タイトル: {e.title}</div>
          <div>開始: {formatDate(e.start_at)}</div>
          <div>workspace: {e.workspace_type}</div>
          <div>タグ: {e.tags.length > 0 ? e.tags.join(" / ") : "なし"}</div>

          {e.delete_status === "none" && (
            <button
              type="button"
              onClick={() => handleDelete(e.id, e.workspace_type)}
              style={{
                marginTop: 8,
                padding: "8px 12px",
                border: "1px solid orange",
                background: "#222",
                color: "orange",
                cursor: "pointer",
                minHeight: 40,
              }}
            >
              削除
            </button>
          )}

          {e.delete_status === "requested" && (
            <>
              <div style={{ color: "orange", marginTop: 8 }}>削除申請中</div>

              {(currentRole === "admin" ||
                currentRole === "owner" ||
                currentRole === "owner_ceo") && (
                <button
                  type="button"
                  onClick={() => handleApprove(e.id)}
                  style={{
                    marginTop: 8,
                    padding: "8px 12px",
                    border: "1px solid red",
                    background: "#222",
                    color: "red",
                    cursor: "pointer",
                    minHeight: 40,
                  }}
                >
                  削除確定
                </button>
              )}
            </>
          )}
        </div>
      ))}
    </div>
  );
}