import type { Event, Role } from "./event.types";

export type CreateEventInput = {
  title: string;
  description?: string | null;
  tags?: string[];

  start_at: string;
  end_at?: string | null;
  all_day?: boolean;

  workspace_type: "private" | "business";
  workspace_id: string;
  created_by: string;

  participant_user_ids?: string[];
  mention_user_ids?: string[];

  visible_role_min?: Role;
  editable_role_min?: "admin" | "owner" | "owner_ceo";
  manager_can_edit?: boolean;

  location_text?: string | null;
  notify_before_minutes?: number | null;
};

export function createEvent(input: CreateEventInput): Event {
  const now = new Date().toISOString();

  return {
    id: crypto.randomUUID(),

    title: input.title.trim(),
    description: input.description ?? null,
    tags: input.tags ?? [],

    start_at: input.start_at,
    end_at: input.end_at ?? null,
    all_day: input.all_day ?? false,

    workspace_type: input.workspace_type,
    workspace_id: input.workspace_id,
    created_by: input.created_by,

    status: "draft",

    participant_user_ids: input.participant_user_ids ?? [],
    mention_user_ids: input.mention_user_ids ?? [],

    visible_role_min: input.visible_role_min ?? "member",

    editable_role_min: input.editable_role_min ?? "admin",
    manager_can_edit: input.manager_can_edit ?? false,

    delete_status: "none",
    delete_requested_by: null,
    delete_requested_at: null,
    delete_reviewed_by: null,
    delete_reviewed_at: null,
    delete_review_result: null,

    location_text: input.location_text ?? null,
    notify_before_minutes: input.notify_before_minutes ?? null,

    has_chat: true,

    created_at: now,
    updated_at: now,
  };
}

export function confirmEvent(event: Event): Event {
  return {
    ...event,
    status: "confirmed",
    updated_at: new Date().toISOString(),
  };
}

export function requestDeleteEvent(event: Event, userId: string): Event {
  return {
    ...event,
    delete_status: "requested",
    delete_requested_by: userId,
    delete_requested_at: new Date().toISOString(),
    delete_reviewed_by: null,
    delete_reviewed_at: null,
    delete_review_result: "pending",
    updated_at: new Date().toISOString(),
  };
}

export function approveDeleteEvent(event: Event, reviewerId: string): Event {
  return {
    ...event,
    delete_status: "deleted",
    delete_reviewed_by: reviewerId,
    delete_reviewed_at: new Date().toISOString(),
    delete_review_result: "approved",
    updated_at: new Date().toISOString(),
  };
}

export function rejectDeleteEvent(event: Event, reviewerId: string): Event {
  return {
    ...event,
    delete_status: "none",
    delete_reviewed_by: reviewerId,
    delete_reviewed_at: new Date().toISOString(),
    delete_review_result: "rejected",
    updated_at: new Date().toISOString(),
  };
}

export function canDirectEditEvent(role: Role, event: Event): boolean {
  if (role === "owner_ceo" || role === "owner" || role === "admin") {
    return true;
  }

  if (role === "manager" && event.manager_can_edit) {
    return true;
  }

  return false;
}

export function canViewEvent(role: Role, event: Event, userId?: string): boolean {
  const roleOrder: Record<Role, number> = {
    member: 1,
    manager: 2,
    admin: 3,
    owner: 4,
    owner_ceo: 5,
  };

  if (userId && event.mention_user_ids.includes(userId)) {
    return true;
  }

  return roleOrder[role] >= roleOrder[event.visible_role_min];
}