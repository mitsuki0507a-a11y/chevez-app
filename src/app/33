"use client";

import { useEffect, useRef, useState } from "react";
import { createEvent } from "../features/event/event.service";
import { parseEventText } from "../features/parser/parser";
import type { Event, Role } from "../features/event/event.types";

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${d.getFullYear()}/${d.getMonth() + 1}/${d.getDate()} ${String(
    d.getHours()
  ).padStart(2, "0")}:${String(d.getMinutes()).padStart(2, "0")}`;
}

type PreviewEvent = {
  title: string;
  tags: string[];
  start_at: string;
  workspace_type: "private" | "business";
};

export default function Page() {
  const [events, setEvents] = useState<Event[]>([]);
  const [inputText, setInputText] = useState("");
  const [preview, setPreview] = useState<PreviewEvent | null>(null);
  const [currentWorkspaceType, setCurrentWorkspaceType] =
    useState<"private" | "business">("private");
  const [debugMessage, setDebugMessage] = useState("待機中");

  const previewRef = useRef<HTMLDivElement | null>(null);

  const currentRole: Role = "admin";

  const deleteMode = {
    private: "direct",
    business: "approval",
  } as const;

  useEffect(() => {
    if (preview && previewRef.current) {
      setTimeout(() => {
        previewRef.current?.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      }, 100);
    }
  }, [preview]);

  const handleWorkspaceChange = (type: "private" | "business") => {
    setCurrentWorkspaceType(type);
    setDebugMessage(`workspace変更: ${type}`);
  };

  const handleRegister = () => {
    setDebugMessage("登録ボタン反応");

    const trimmed = inputText.trim();

    if (!trimmed) {
      setDebugMessage("入力空");
      alert("入力して");
      return;
    }

    const parsed = parseEventText(trimmed);
    const dt = parsed.parsedDateTime;

    if (!dt) {
      setDebugMessage("解析失敗");
      alert("解析できない");
      return;
    }

    const date = new Date(
      dt.year,
      dt.month - 1,
      dt.day,
      dt.hour,
      dt.minute
    );

    if (isNaN(date.getTime())) {
      setDebugMessage("日付異常");
      alert("日付おかしい");
      return;
    }

    if (typeof document !== "undefined") {
      const active = document.activeElement as HTMLElement | null;
      active?.blur();
    }

    setPreview({
      title: parsed.title,
      tags: parsed.tags,
      start_at: date.toISOString(),
      workspace_type: currentWorkspaceType,
    });

    setDebugMessage("確認表示中");
  };

  const handleConfirm = () => {
    if (!preview) {
      setDebugMessage("previewなし");
      return;
    }

    const event = createEvent({
      title: preview.title,
      tags: preview.tags,
      start_at: preview.start_at,
      end_at: null,
      all_day: false,
      workspace_type: preview.workspace_type,
      workspace_id:
        preview.workspace_type === "private"
          ? "private-main"
          : "business-main",
      created_by: "me",
    });

    setEvents((prev) => [...prev, event]);
    setPreview(null);
    setInputText("");
    setDebugMessage("保存完了");
  };

  const handleCancel = () => {
    setPreview(null);
    setDebugMessage("確認キャンセル");
  };

  const handleDelete = (id: string, workspaceType: "private" | "business") => {
    if (deleteMode[workspaceType] === "direct") {
      setEvents((prev) =>
        prev.map((e) =>
          e.id === id
            ? {
                ...e,
                delete_status: "deleted",
                updated_at: new Date().toISOString(),
              }
            : e
        )
      );
      setDebugMessage("private削除完了");
      return;
    }

    setEvents((prev) =>
      prev.map((e) =>
        e.id === id
          ? {
              ...e,
              delete_status: "requested",
              delete_requested_by: "me",
              delete_requested_at: new Date().toISOString(),
              delete_review_result: "pending",
              updated_at: new Date().toISOString(),
            }
          : e
      )
    );
    setDebugMessage("business削除申請");
  };

  const handleApprove = (id: string) => {
    if (
      currentRole !== "admin" &&
      currentRole !== "owner" &&
      currentRole !== "owner_ceo"
    ) {
      setDebugMessage("削除承認権限なし");
      return;
    }

    setEvents((prev) =>
      prev.map((e) =>
        e.id === id
          ? {
              ...e,
              delete_status: "deleted",
              delete_reviewed_by: "me",
              delete_reviewed_at: new Date().toISOString(),
              delete_review_result: "approved",
              updated_at: new Date().toISOString(),
            }
          : e
      )
    );
    setDebugMessage("削除承認完了");
  };

  const filteredEvents = events.filter(
    (e) =>
      e.workspace_type === currentWorkspaceType &&
      e.delete_status !== "deleted"
  );

  return (
    <div
      style={{
        padding: 20,
        color: "white",
        background: "#111",
        minHeight: "100vh",
      }}
    >
      <h1>チャベス</h1>

      <div style={{ marginBottom: 12 }}>
        <div>workspace: {currentWorkspaceType}</div>
        <div>role: {currentRole}</div>
        <div>debug: {debugMessage}</div>
      </div>

      <div
        style={{
          display: "flex",
          gap: 8,
          marginBottom: 16,
          flexWrap: "wrap",
        }}
      >
        <button
          type="button"
          onPointerUp={() => handleWorkspaceChange("private")}
          style={{
            padding: "12px 16px",
            border: "1px solid white",
            background: currentWorkspaceType === "private" ? "white" : "#222",
            color: currentWorkspaceType === "private" ? "black" : "white",
            cursor: "pointer",
            minHeight: 44,
            touchAction: "manipulation",
          }}
        >
          private
        </button>

        <button
          type="button"
          onPointerUp={() => handleWorkspaceChange("business")}
          style={{
            padding: "12px 16px",
            border: "1px solid white",
            background: currentWorkspaceType === "business" ? "white" : "#222",
            color: currentWorkspaceType === "business" ? "black" : "white",
            cursor: "pointer",
            minHeight: 44,
            touchAction: "manipulation",
          }}
        >
          business
        </button>
      </div>

      <div
        style={{
          display: "flex",
          gap: 8,
          marginBottom: 16,
          flexWrap: "wrap",
          alignItems: "center",
        }}
      >
        <input
          type="text"
          value={inputText}
          onChange={(e) => setInputText(e.target.value)}
          placeholder="例: 来週金曜重要会議"
          style={{
            padding: "12px",
            border: "1px solid white",
            background: "#222",
            color: "white",
            width: 320,
            maxWidth: "100%",
            minHeight: 44,
            fontSize: 16,
          }}
        />

        <button
          type="button"
          onPointerUp={handleRegister}
          style={{
            padding: "12px 16px",
            border: "1px solid white",
            background: "#222",
            color: "white",
            cursor: "pointer",
            minHeight: 44,
            touchAction: "manipulation",
          }}
        >
          登録
        </button>
      </div>

      {preview && (
        <div
          ref={previewRef}
          style={{
            border: "1px solid #666",
            padding: 12,
            marginBottom: 16,
            background: "#1a1a1a",
          }}
        >
          <h2>確認</h2>
          <div>タイトル: {preview.title}</div>
          <div>開始: {formatDate(preview.start_at)}</div>
          <div>workspace: {preview.workspace_type}</div>
          <div>
            タグ: {preview.tags.length > 0 ? preview.tags.join(" / ") : "なし"}
          </div>

          <div style={{ display: "flex", gap: 8, marginTop: 12, flexWrap: "wrap" }}>
            <button
              type="button"
              onPointerUp={handleConfirm}
              style={{
                padding: "12px 16px",
                border: "1px solid #0f0",
                background: "#222",
                color: "#0f0",
                cursor: "pointer",
                minHeight: 44,
                touchAction: "manipulation",
              }}
            >
              確定
            </button>

            <button
              type="button"
              onPointerUp={handleCancel}
              style={{
                padding: "12px 16px",
                border: "1px solid #aaa",
                background: "#222",
                color: "#aaa",
                cursor: "pointer",
                minHeight: 44,
                touchAction: "manipulation",
              }}
            >
              キャンセル
            </button>
          </div>
        </div>
      )}

      <h2>予定一覧</h2>

      {filteredEvents.length === 0 && <p>このworkspaceの予定はまだなし</p>}

      {filteredEvents.map((e) => (
        <div
          key={e.id}
          style={{
            marginBottom: 14,
            padding: 12,
            border: "1px solid #444",
          }}
        >
          <div>タイトル: {e.title}</div>
          <div>開始: {formatDate(e.start_at)}</div>
          <div>workspace: {e.workspace_type}</div>
          <div>タグ: {e.tags.length > 0 ? e.tags.join(" / ") : "なし"}</div>

          {e.delete_status === "none" && (
            <button
              type="button"
              onPointerUp={() => handleDelete(e.id, e.workspace_type)}
              style={{
                marginTop: 8,
                padding: "10px 12px",
                border: "1px solid orange",
                background: "#222",
                color: "orange",
                cursor: "pointer",
                minHeight: 40,
                touchAction: "manipulation",
              }}
            >
              削除
            </button>
          )}

          {e.delete_status === "requested" && (
            <>
              <div style={{ color: "orange", marginTop: 8 }}>削除申請中</div>

              {(currentRole === "admin" ||
                currentRole === "owner" ||
                currentRole === "owner_ceo") && (
                <button
                  type="button"
                  onPointerUp={() => handleApprove(e.id)}
                  style={{
                    marginTop: 8,
                    padding: "10px 12px",
                    border: "1px solid red",
                    background: "#222",
                    color: "red",
                    cursor: "pointer",
                    minHeight: 40,
                    touchAction: "manipulation",
                  }}
                >
                  削除確定
                </button>
              )}
            </>
          )}
        </div>
      ))}
    </div>
  );
}